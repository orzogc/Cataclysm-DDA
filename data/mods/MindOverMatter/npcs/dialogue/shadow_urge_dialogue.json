  {
    "id": [ "TALK_MOM_SHADOW_URGE_MACHINE" ],
    "type": "talk_topic",
    "dynamic_line": [
      {
        "u_is_on_furniture": "f_biokinetic_physiology_improver",
        "yes": "&You sit down and activate the screen, trying to ignore your awkward positioning, and within a few moments are greeted with a login prompt.\n\n\"Project SHADOW URGE.  Enter login credentials.\"",
        "no": "&You poke at the computer, and while it does turn on and you see a login screen for a moment, it's quickly replaced with a popup that reads:\n\n\"No occupant detected.  SHADOW URGE functions unavailable.\""
      }
    ],
    "responses": [
      {
        "text": "Input the SHADOW URGE access codes you have.",
        "topic": "COMP_MOM_SHADOW_URGE_COMPUTER_KNOWN_PASS",
        "condition": {
          "and": [ { "u_is_on_furniture": "f_biokinetic_physiology_improver" }, { "u_has_item": "lab_file_shadow_urge_password" } ]
        }
      },
      {
        "text": "Try a random username and password.",
        "topic": "COMP_MOM_SHADOW_URGE_COMPUTER_RANDOM_PASS",
        "condition": {
          "and": [
            { "u_is_on_furniture": "f_biokinetic_physiology_improver" },
            { "not": { "u_has_item": "lab_file_shadow_urge_password" } }
          ]
        }
      },
      {
        "text": "Better sit down.",
        "topic": "TALK_DONE",
        "condition": { "not": { "u_is_on_furniture": "f_biokinetic_physiology_improver" } }
      }
    ]
  },
  {
