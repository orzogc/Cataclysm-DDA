          { "run_eocs": "EOC_CHANGELING_SUMMER_PROTECT_FROM_HOT_WEATHER", "alpha_talker": "u" },
          {
            "math": [
              "n_val('mana') -= max( ( 250 - (n_spell_count('school': 'CHANGELING_SEASONAL_MAGIC_SUMMER') * 2) - (n_skill('gramarye') * 4.5) ), 100)"
            ]
          }
        ]
      }
    ]
  }
